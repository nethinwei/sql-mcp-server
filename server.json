{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.nethinwei/sql-mcp-server",
  "title": "SQL MCP Server",
  "description": "Controlled SQL access gateway with policy, cost limits, tenant isolation, and safe tools.",
  "version": "0.1.6",
  "websiteUrl": "https://github.com/nethinwei/sql-mcp-server",
  "repository": {
    "url": "https://github.com/nethinwei/sql-mcp-server",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "oci",
      "identifier": "ghcr.io/nethinwei/sql-mcp-server:0.1.6",
      "runtimeHint": "docker",
      "transport": {
        "type": "stdio"
      },
      "runtimeArguments": [
        {
          "type": "named",
          "name": "--mount",
          "value": "type=bind,src={config_path},dst=/config/config.yaml,readonly",
          "isRequired": true,
          "variables": {
            "config_path": {
              "description": "Absolute path to the SQL MCP Server YAML configuration",
              "format": "filepath",
              "isRequired": true
            }
          }
        }
      ],
      "packageArguments": [
        {
          "type": "positional",
          "value": "serve"
        },
        {
          "type": "named",
          "name": "--config",
          "value": "/config/config.yaml"
        },
        {
          "type": "named",
          "name": "--transport",
          "value": "stdio"
        }
      ],
      "environmentVariables": [
        {
          "name": "DATABASE_DSN",
          "description": "Database DSN referenced by ${DATABASE_DSN} in config.yaml",
          "isRequired": false,
          "isSecret": true
        }
      ]
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "capabilities": {
        "transports": ["stdio", "streamable-http"],
        "authentication": ["shared-bearer-token", "mTLS", "trusted-proxy-identity"],
        "providers": ["postgres", "mysql", "oceanbase"],
        "security": [
          "generated-parameterized-sql",
          "RBAC-and-row-policies",
          "field-masking",
          "fail-closed-cost-gates"
        ]
      },
      "documentation": {
        "quickstart": "https://github.com/nethinwei/sql-mcp-server/blob/main/docs/quickstart.md",
        "security": "https://github.com/nethinwei/sql-mcp-server/blob/main/docs/security.md",
        "providers": "https://github.com/nethinwei/sql-mcp-server/blob/main/docs/provider-compatibility.md"
      }
    }
  }
}
