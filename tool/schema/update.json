{
    "type": "object",
    "properties": {
        "entity": {
            "type": "string"
        },
        "transaction": {
            "type": "string",
            "description": "Token returned by begin_transaction"
        },
        "filter": {
            "type": "array",
            "maxItems": 32,
            "items": {
                "type": "object",
                "properties": {
                    "field": {
                        "type": "string"
                    },
                    "op": {
                        "type": "string",
                        "enum": [
                            "eq",
                            "ne",
                            "gt",
                            "gte",
                            "lt",
                            "lte",
                            "in",
                            "not_in",
                            "like",
                            "is_null",
                            "is_not_null"
                        ]
                    },
                    "value": {
                        "description": "Value (array for in/not_in; omitted for is_null/is_not_null)"
                    }
                },
                "required": [
                    "field",
                    "op"
                ]
            }
        },
        "set": {
            "type": "object",
            "description": "Column name to new value map"
        }
    },
    "required": [
        "entity",
        "filter",
        "set"
    ]
}