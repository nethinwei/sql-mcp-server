{
  "mcpServers": {
    "sql-mcp-server": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "--mount",
        "type=bind,src=/absolute/path/to/config.yaml,dst=/config/config.yaml,readonly",
        "--env",
        "DATABASE_DSN",
        "ghcr.io/nethinwei/sql-mcp-server:0.1.3",
        "serve",
        "--config",
        "/config/config.yaml",
        "--transport",
        "stdio",
        "--role",
        "reader"
      ],
      "env": {
        "DATABASE_DSN": "postgres://reader:password@host.docker.internal:5432/app?sslmode=require"
      }
    }
  }
}
