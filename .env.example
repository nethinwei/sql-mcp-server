# 本地环境变量样例。复制为 .env 后填写；.env 已被 gitignore，绝不提交。
# Makefile 会自动加载 .env（见顶部 -include），make eval-pilot 等目标可直接使用。

# ---- Agent Eval pilot（make eval-pilot，必填）----
# OpenAI 兼容端点的 API key 与模型（需支持 chat completions + tool calling）。
EVAL_API_KEY=
EVAL_MODEL=
# 端点基址，默认 https://api.openai.com/v1；兼容端点示例：
#   https://api.deepseek.com/v1
#   https://dashscope.aliyuncs.com/compatible-mode/v1
EVAL_BASE_URL=
# 任务并行度，默认 6（受 eval/config.yaml 的 budget.maxConcurrent=16 约束，
# 调高时注意端点限流）。
EVAL_PARALLEL=

# ---- OpenTelemetry（可选）----
# 设置后 serve 会初始化 OTLP HTTP/protobuf trace exporter；留空保持 no-op。
OTEL_EXPORTER_OTLP_ENDPOINT=

# ---- 本地 serve（可选）----
# 配置文件中 dsn: "${DATABASE_DSN}" 的取值；仅供你在 shell 中手动 source 使用，
# 各 smoke/benchmark 会自行启动 testcontainers 并覆盖该值。
DATABASE_DSN=

# ---- benchmark 覆盖（可选，默认 10000 / 2000）----
BENCH_ROWS=
BENCH_ITERATIONS=
