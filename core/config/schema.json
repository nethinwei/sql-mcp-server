{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sql-mcp-server configuration",
  "type": "object",
  "anyOf": [
    {"required": ["database"]},
    {"required": ["databases"]}
  ],
  "properties": {
    "version": {"type": "string"},
    "server": {
      "type": "object",
      "properties": {
        "transport": {"type": "string", "enum": ["stdio", "http"]},
        "addr": {"type": "string"},
        "role": {"type": "string"},
        "secrets": {
          "type": "object",
          "properties": {
            "allowedRoots": {"type": "array", "items": {"type": "string"}}
          }
        },
        "auth": {
          "type": "object",
          "properties": {
            "token": {"type": "string"},
            "trustProxyHeaders": {"type": "boolean"},
            "trustedProxyCIDRs": {"type": "array", "items": {"type": "string"}},
            "tls": {
              "type": "object",
              "properties": {
                "cert": {"type": "string"},
                "key": {"type": "string"},
                "clientCA": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "database": {"$ref": "#/$defs/database"},
    "databases": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/database"}
    },
    "entities": {
      "type": "array",
      "items": {"$ref": "#/$defs/entity"}
    },
    "tools": {
      "type": "object",
      "properties": {
        "describeEntities": {"type": "boolean"},
        "readRecords": {"type": "boolean"},
        "createRecord": {"type": "boolean"},
        "updateRecord": {"type": "boolean"},
        "deleteRecord": {"type": "boolean"},
        "executeEntity": {"type": "boolean"},
        "aggregateRecords": {"type": "boolean"},
        "beginTransaction": {"type": "boolean"},
        "commitTransaction": {"type": "boolean"},
        "rollbackTransaction": {"type": "boolean"}
      }
    },
    "cost": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "softScore": {"type": "integer", "minimum": 0, "maximum": 100},
        "hardScore": {"type": "integer", "minimum": 0, "maximum": 100},
        "maxRows": {"type": "integer", "minimum": 1},
        "maxBytes": {"type": "integer", "minimum": 1},
        "maxINListSize": {"type": "integer", "minimum": 1},
        "maxFilterConditions": {"type": "integer", "minimum": 1},
        "maxGroupByFields": {"type": "integer", "minimum": 1},
        "maxAggregates": {"type": "integer", "minimum": 1},
        "maxExpand": {"type": "integer", "minimum": 1},
        "maxProcedureRows": {"type": "integer", "minimum": 1},
        "rejectFullScan": {"type": "boolean"},
        "whitelistPKPoint": {"type": "boolean"},
        "requirePKForWrite": {"type": "boolean"},
        "requireKnownScan": {"type": "boolean"},
        "requireFreshStats": {"type": "boolean"},
        "queryTimeout": {"type": "string"},
        "allowTemplates": {"type": "array", "items": {"type": "string"}},
        "rejectTemplates": {"type": "array", "items": {"type": "string"}},
        "aqe": {
          "type": "object",
          "properties": {
            "windowSize": {"type": "integer", "minimum": 0},
            "anomalyFactor": {"type": "number", "minimum": 0},
            "anomalyMinSamples": {"type": "integer", "minimum": 0},
            "explainAnalyze": {"type": "boolean"},
            "readOnly": {"type": "boolean"},
            "sampleRate": {"type": "number", "minimum": 0, "maximum": 1},
            "timeout": {"type": "string"},
            "maxFingerprints": {"type": "integer", "minimum": 1}
          }
        }
      }
    },
    "budget": {
      "type": "object",
      "properties": {
        "roles": {"type": "object", "additionalProperties": {"$ref": "#/$defs/budgetLimits"}},
        "tenants": {"type": "object", "additionalProperties": {"$ref": "#/$defs/budgetLimits"}}
      }
    },
    "cache": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "ttl": {"type": "string"},
        "maxSize": {"type": "integer", "minimum": 0},
        "maxEntryRows": {"type": "integer", "minimum": 1},
        "maxEntryBytes": {"type": "integer", "minimum": 1},
        "preparedMaxSize": {"type": "integer", "minimum": 0}
      }
    },
    "rateLimit": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "rps": {"type": "number", "minimum": 0},
        "maxInflight": {"type": "integer", "minimum": 0},
        "ioPool": {"type": "integer", "minimum": 0},
        "cpuPool": {"type": "integer", "minimum": 0},
        "minConcurrency": {"type": "integer", "minimum": 0},
        "rttThreshold": {"type": "string"},
        "breakerThreshold": {"type": "integer", "minimum": 0},
        "breakerCooldown": {"type": "string"},
        "connMaxIdleTime": {"type": "string"},
        "connMaxLifetime": {"type": "string"}
      }
    },
    "mask": {"type": "object", "properties": {"enabled": {"type": "boolean"}}},
    "audit": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "path": {"type": "string"},
        "queueSize": {"type": "integer", "minimum": 0}
      }
    },
    "transactions": {
      "type": "object",
      "properties": {
        "ttl": {"type": "string"},
        "maxOpen": {"type": "integer", "minimum": 0},
        "beginTimeout": {"type": "string"},
        "commitTimeout": {"type": "string"},
        "rollbackTimeout": {"type": "string"}
      }
    }
  },
  "$defs": {
    "database": {
      "type": "object",
      "required": ["driver", "dsn"],
      "properties": {
        "driver": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$",
          "description": "Registered provider name."
        },
        "dsn": {"type": "string", "minLength": 1}
      }
    },
    "budgetLimits": {
      "type": "object",
      "properties": {
        "maxConcurrent": {"type": "integer", "minimum": 0},
        "maxExecution": {"type": "string"},
        "maxEstimatedScannedRows": {"type": "integer", "minimum": 0},
        "maxScannedRows": {"type": "integer", "minimum": 0},
        "maxReturnedRows": {"type": "integer", "minimum": 0},
        "maxReturnedBytes": {"type": "integer", "minimum": 0},
        "maxSessionCost": {"type": "integer", "minimum": 0}
      }
    },
    "entity": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "source": {"type": "string"},
        "datasource": {"type": "string"},
        "schema": {"type": "string"},
        "kind": {"type": "string", "enum": ["table", "view", "procedure"]},
        "description": {"type": "string"},
        "primaryKey": {"type": "array", "items": {"type": "string"}},
        "params": {"type": "array", "items": {"type": "string"}},
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {"type": "string"},
              "alias": {"type": "string"},
              "description": {"type": "string"},
              "mask": {"type": "string"},
              "exclude": {"type": "boolean"}
            }
          }
        },
        "roles": {"type": "object"},
        "fieldACL": {"type": "object"},
        "rowPolicies": {"type": "object"},
        "relationships": {"type": "array"},
        "mcp": {
          "type": "object",
          "properties": {
            "dmlTools": {"type": "boolean"},
            "customTool": {"type": "boolean"},
            "trustedProcedure": {"type": "boolean"}
          }
        }
      }
    }
  }
}
